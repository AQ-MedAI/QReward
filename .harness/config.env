#!/usr/bin/env bash
# ============================================================
# QReward — Harness Configuration
# ============================================================

# ── Python & Build ──────────────────────────────────────────
PYTHON_MIN_VERSION="3.10"
BUILD_CMD="python setup.py sdist bdist_wheel"
TEST_CMD="pytest --cov=qreward"
LINT_CMD="make lint"

# ── Scoring ─────────────────────────────────────────────────
SCORE_TOTAL=100
SCORE_BUILD=25
SCORE_FUNCTIONALITY=30
SCORE_TEST=15
SCORE_ARCH=20
SCORE_QUALITY=10
SCORE_PASS_THRESHOLD=90

# ── Test Thresholds ─────────────────────────────────────────
INCREMENTAL_COVERAGE_MIN=70
MAX_FILE_LINES=400
MAX_FUNCTION_LINES=50

# ── Iteration ───────────────────────────────────────────────
MAX_ITERATE_ROUNDS=3
PREFLIGHT_TIMEOUT=30
EVALUATE_TIMEOUT=300

# ── Paths ───────────────────────────────────────────────────
SRC_DIR="qreward"
TEST_DIR="tests"
SPRINT_DIR=".harness/sprints"
SCRIPT_DIR=".harness/scripts"
ARTIFACT_DIR=".harness/artifacts"
